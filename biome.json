{
  "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
  "files": {
    "includes": [
      "**",
      "!packages/*/drizzle",
      "!packages/console/src/components/ui",
      "!packages/console/src/hooks/use-mobile.ts",
      "!packages/console/src/lib/utils.ts",
      "!packages/console/src/shadcn.css",
      "!packages/console/src/routeTree.gen.ts",
      "!website/src/components/ui",
      "!website/src/hooks/use-mobile.ts",
      "!website/src/lib/utils.ts",
      "!website/src/app/shadcn.css"
    ]
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended"
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  }
}
