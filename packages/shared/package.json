{
  "name": "@dormice/shared",
  "version": "0.1.0",
  "description": "Protocol types and schemas shared by the Dormice server, SDK, and WebUI",
  "keywords": [
    "dormice",
    "sandbox",
    "protocol",
    "schemas",
    "zod"
  ],
  "license": "Apache-2.0",
  "homepage": "https://github.com/BitMiracle-AI/Dormice#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BitMiracle-AI/Dormice.git",
    "directory": "packages/shared"
  },
  "bugs": "https://github.com/BitMiracle-AI/Dormice/issues",
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
