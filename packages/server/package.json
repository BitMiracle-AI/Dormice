{
  "name": "@dormice/server",
  "version": "0.0.0",
  "private": true,
  "description": "Dormice daemon: sandbox lifecycle over Docker + gVisor, SQLite ledger",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "drizzle"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/main.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@dormice/shared": "workspace:*",
    "@fastify/cookie": "^11.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "better-sqlite3": "^12.11.1",
    "dockerode": "^5.0.1",
    "drizzle-orm": "^0.45.2",
    "execa": "^9.6.1",
    "fastify": "^5.10.0",
    "fastify-type-provider-zod": "^7.0.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/dockerode": "^4.0.1",
    "drizzle-kit": "^0.31.10"
  }
}
