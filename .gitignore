# ── Internal development files, never committed ──
# CLAUDE.md carries private cross-references; RULES/ and docs/ are internal
# conventions and decision records. Public-facing docs (README, SECURITY.md, …)
# are separate deliverables written on their own. Anchored to the repo root:
# an unanchored docs/ would swallow website/content/docs/ too.
CLAUDE.md
/RULES/
/docs/

# Scratch code for verification and research (see RULES/临时代码.md):
# deleted when done, and a public repo's history is append-only — one
# accidental commit would be permanent
temp/

# Secrets and real env files (only *.example may be committed)
.env
.env.*
!.env.example
*.pem
*.key

# Node / pnpm
node_modules/
dist/
*.tsbuildinfo

# website (Next.js) build artifacts and generated files
website/.next/
website/out/
website/next-env.d.ts

# Runtime data (SQLite ledger, sandbox volumes)
data/

# Tests and coverage
coverage/

# System and editors
.DS_Store
.idea/
.vscode/

# Logs
*.log
